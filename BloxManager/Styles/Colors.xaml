<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Neutrals -->
    <Color x:Key="BackgroundMainColor">#0F0F12</Color>
    <SolidColorBrush x:Key="BackgroundMainBrush" Color="{StaticResource BackgroundMainColor}"/>
    
    <Color x:Key="BackgroundSecondaryColor">#1A1A1F</Color>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}"/>

    <Color x:Key="SurfaceColor">#25252B</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>

    <!-- Professional Status Colors -->
    <SolidColorBrush x:Key="OnlineStatusBrush" Color="#10B981"/> <!-- Emerald -->
    <SolidColorBrush x:Key="OfflineStatusBrush" Color="#64748B"/> <!-- Slate -->
    <SolidColorBrush x:Key="AwayStatusBrush" Color="#F59E0B"/>    <!-- Amber -->
    <SolidColorBrush x:Key="InGameStatusBrush" Color="#3B82F6"/>   <!-- Blue -->
    <SolidColorBrush x:Key="ErrorStatusBrush" Color="#EF4444"/>    <!-- Red -->
    <SolidColorBrush x:Key="WarningStatusBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="SuccessStatusBrush" Color="#10B981"/>

    <!-- Accent Gradients -->
    <LinearGradientBrush x:Key="PrimaryAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/> <!-- Indigo -->
        <GradientStop Color="#A855F7" Offset="1"/> <!-- Purple -->
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SecondaryAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0EA5E9" Offset="0"/> <!-- Sky -->
        <GradientStop Color="#2DD4BF" Offset="1"/> <!-- Teal -->
    </LinearGradientBrush>

    <!-- Glassmorphism Resources -->
    <SolidColorBrush x:Key="GlassBackgroundBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#2AFFFFFF" />
    <SolidColorBrush x:Key="FrostedBackgroundBrush" Color="#CC16161A" />
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>

    <!-- Converters (Retained from original) -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#6366F1"/>

    <!-- Input -->
    <Style x:Key="Input" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="#A855F7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#6366F1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style x:Key="Combo" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ItemRoot" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource GlassBackgroundBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" Content="{TemplateBinding SelectionBoxItem}"
                                                  VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ToggleButton Grid.Column="1" Width="24" Height="24" Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <Path Data="M7,10L12,15L17,10H7Z" Fill="{StaticResource TextSecondaryBrush}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <ToggleButton Background="Transparent" BorderThickness="0" Focusable="False"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      Grid.RowSpan="1"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Panel.ZIndex="98">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom" AllowsTransparency="True">
                            <Border Background="{StaticResource BackgroundSecondaryBrush}" 
                                    BorderBrush="{StaticResource GlassBorderBrush}" 
                                    BorderThickness="1"
                                    CornerRadius="8" Margin="0,4,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                                </Border.Effect>
                                <ItemsPresenter/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <BulletDecorator Background="Transparent" SnapsToDevicePixels="true">
                        <BulletDecorator.Bullet>
                            <Border x:Name="BulletRoot" 
                                    Width="18" Height="18" 
                                    BorderThickness="1" 
                                    CornerRadius="4" 
                                    BorderBrush="{StaticResource GlassBorderBrush}" 
                                    Background="{StaticResource BackgroundMainBrush}">
                                <Path x:Name="CheckMark" 
                                      Data="M1,4.5 L3.5,7 L8,1" 
                                      Stroke="White" 
                                      StrokeThickness="2" 
                                      Margin="3" 
                                      Visibility="Collapsed"
                                      Stretch="Uniform"/>
                            </Border>
                        </BulletDecorator.Bullet>
                        <ContentPresenter Margin="{TemplateBinding Padding}" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                          RecognizesAccessKey="True" 
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </BulletDecorator>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="true">
                            <Setter TargetName="BulletRoot" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter TargetName="BulletRoot" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="BulletRoot" Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Alignment Button Style -->
    <Style x:Key="AlignmentButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource GlassBackgroundBrush}"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="Center">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="Top">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="Left">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="Right">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="Bottom">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="TopLeft">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="TopRight">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="BottomLeft">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=DataContext.BackgroundImageAlignment}" Value="BottomRight">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#6366F1" Opacity="0.5" ShadowDepth="2" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="Margin" Value="0,4,0,12"/>
    </Style>
</ResourceDictionary>
