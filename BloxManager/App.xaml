<Application x:Class="BloxManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:BloxManager.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design -->
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                
                <!-- Custom Styles -->
                <ResourceDictionary Source="Styles/Buttons.xaml" />
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Cards.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
            <converters:UsernameToColorConverter x:Key="UsernameToColorConverter"/>
            <converters:UsernameToInitialsConverter x:Key="UsernameToInitialsConverter"/>
            <converters:AccountStatusToColorConverter x:Key="AccountStatusToColorConverter"/>
            <converters:MultiParamConverter x:Key="MultiParamConverter"/>
            <converters:IntToBoolConverter x:Key="IntToBoolConverter"/>
            <converters:BoolToAngleConverter x:Key="BoolToAngleConverter"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:PathToImageBrushConverter x:Key="PathToImageBrushConverter"/>
            <converters:PathToImageSourceConverter x:Key="PathToImageSourceConverter"/>
            <converters:EqualityConverter x:Key="EqualityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
