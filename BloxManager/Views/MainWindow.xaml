<Window x:Class="BloxManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BloxManager.Views"
        xmlns:Models="clr-namespace:BloxManager.Models"
        xmlns:views="clr-namespace:BloxManager.Views"
         Title="BloxManager"
         Height="420" Width="900"
         WindowStartupLocation="CenterScreen"
         WindowStyle="SingleBorderWindow"
         AllowsTransparency="False"
         ResizeMode="CanMinimize"
         Background="{StaticResource BackgroundMainBrush}"
         TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="Segoe UI Variable, Segoe UI, Arial"
        Icon="pack://application:,,,/Assets/BloxManager_Logo.ico">

    <Window.Resources>
        <!-- Icons -->
        <Geometry x:Key="IconAccounts">M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4-4,1.79-4,4,1.79,4,4,4Zm0,2c-2.67,0-8,1.34-8,4v2h16v-2c0-2.66-5.33-4-8-4Z</Geometry>
        <Geometry x:Key="IconGames">M21,6H3C1.9,6,1,6.9,1,8v8c0,1.1,0.9,2,2,2h18c1.1,0,2-0.9,2-2V8C23,6.9,22.1,6,21,6z M11,15H9v-2h2V15z M11,11H9V9h2V11z M15,13h-4v-2h4V13z M19,15h-2v-2h2V15z M19,11h-2V9h2V11z</Geometry>
        <Geometry x:Key="IconSettings">M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41l-0.36,2.54c-0.59,0.24-1.13,0.57-1.62,0.94l-2.39-0.96c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.82,11.69,4.82,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.5c-1.93,0-3.5-1.57-3.5-3.5 s1.57-3.5,3.5-3.5s3.5,1.57,3.5,3.5S13.93,15.5,12,15.5z</Geometry>
        <Geometry x:Key="IconSearch">M15.5,14h-0.79l-0.28-0.27C15.41,12.59,16,11.11,16,9.5c0-3.59-2.91-6.5-6.5-6.5S3,5.91,3,9.5S5.91,16,9.5,16 c1.61,0,3.09-0.59,4.23-1.57L14,14.71v0.79l5,4.99L20.49,19L15.5,14z M9.5,14C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5S14,7.01,14,9.5 S11.99,14,9.5,14z</Geometry>
        <Geometry x:Key="IconPlay">M8,5.14V19.14L19,12.14L8,5.14Z</Geometry>
        <Geometry x:Key="IconAdd">M19,13h-6v6h-2v-6H5v-2h6V5h2v6h6V13z</Geometry>
        <Geometry x:Key="IconJoin">M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z</Geometry>
        <Geometry x:Key="IconRemove">M19,13H5v-2h14V13z</Geometry>
        <Geometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4c-4.42,0-7.99,3.58-7.99,8s3.57,8 7.99,8c3.73,0 6.84-2.55 7.73-6h-2.08 c-0.82,2.33-3.04,4-5.65,4c-3.31,0-6-2.69-6-6s2.69-6,6-6c1.66,0,3.14,0.69,4.22,1.78L13,11h7V4L17.65,6.35z</Geometry>

        <!-- Thin scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                             <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource TextMutedBrush}" CornerRadius="3" Opacity="0.3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar nav item -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="4,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource GlassBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemActive" TargetType="Button" BasedOn="{StaticResource NavItem}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True"> <!-- Just to override the hover for active if needed -->
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <!-- Account row -->
        <Style x:Key="AcctRow" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AcctRowSelected" TargetType="Border" BasedOn="{StaticResource AcctRow}">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Sidebar section label -->
        <Style x:Key="SidebarLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="16,16,0,8"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="180"/>
            <!-- Account list -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════
             SIDEBAR
        ══════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <Image Source="pack://application:,,,/Assets/BloxManager_Logo.Sidebar.png" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <TextBlock Text="BloxManager" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding VersionChannelText}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Nav items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Margin="8,0,8,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SidebarLabel}">CORE</TextBlock>

                        <Button Command="{Binding OpenAccountsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="icon" Data="{StaticResource IconAccounts}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Accounts" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>


                        <Button Command="{Binding OpenSettingsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavItem}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconSettings}" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer / Status -->
                <Border Grid.Row="2" Margin="12,0,12,8" Padding="8" Background="{StaticResource GlassBackgroundBrush}" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="ACCOUNTS ACTIVE" Style="{StaticResource SidebarLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding AccountsInGame}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="SESSION UPTIME" Style="{StaticResource SidebarLabel}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding InGameUptimeText}" FontSize="12" FontFamily="Consolas" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════
             CONTENT AREA
        ══════════════════════════════ -->
        <Grid Grid.Column="1">
            <!-- Account List View -->
            <Grid x:Name="AccountsView">
                <Grid.RowDefinitions>
                    <!-- Topbar -->
                    <RowDefinition Height="68"/>
                    <!-- List -->
                    <RowDefinition Height="*"/>
                    <!-- Status bar -->
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsSettingsOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

            <!-- Topbar -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#99000000"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding BackgroundImagePath}" Value="{x:Null}">
                                <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding BackgroundImagePath}" Value="">
                                <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SettingsViewModel.LowMemoryMode}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Alignment: Search and Filter -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="220">
                            <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextMutedBrush}" 
                                  Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Left" Margin="12,0,0,0"
                                  Panel.ZIndex="1" IsHitTestVisible="False"/>
                            <TextBox Style="{StaticResource Input}" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="34,8,12,8" Tag="Search accounts..."/>
                        </Grid>

                        <Button Style="{StaticResource IconButton}" 
                                Command="{Binding RefreshAllAccountsCommand}"
                                Margin="8,0,0,0" ToolTip="Refresh all">
                            <Path Data="{StaticResource IconRefresh}" Fill="{StaticResource TextSecondaryBrush}" 
                                  Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>

                    <!-- Right Alignment: Actions -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource PrimaryActionButton}" Margin="0,0,8,0" Click="AddAccountButton_Click">
                            <Button.ContextMenu>
                                <ContextMenu Style="{StaticResource DropdownMenu}">
                                    <MenuItem Header="Manual Login" 
                                              Command="{Binding AddAccountCommand}"
                                              Style="{StaticResource DropdownMenuItem}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,4V20M4,12H20" Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="User:Pass" 
                                              Command="{Binding AddAccountUserPassCommand}"
                                              Style="{StaticResource DropdownMenuItem}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,12C14.21,12 16,10.21 16,8C16,5.79 14.21,4 12,4C9.79,4 8,5.79 8,8C8,10.21 9.79,12 12,12M12,14C9.33,14 4,15.33 4,18V20H20V18C20,15.33 14.67,14 12,14Z" Fill="{StaticResource TextPrimaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconAdd}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Add Account"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Style="{StaticResource PrimaryActionButton}" Command="{Binding LaunchSelectedAccountsCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconJoin}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Join Server"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Style="{StaticResource DangerButton}" Command="{Binding RemoveSelectedAccountsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconRemove}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Remove"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Account List -->
            <Grid Grid.Row="1" x:Name="AccountsArea" Loaded="AccountsArea_Loaded" SizeChanged="AccountsArea_SizeChanged" Panel.ZIndex="1">
                <Border x:Name="BackgroundImageLayer"
                        IsHitTestVisible="False"
                        Panel.ZIndex="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SettingsViewModel.LowMemoryMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BackgroundMainBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Image x:Name="BackgroundImage"
                           Opacity="{Binding BackgroundImageOpacity}"
                           IsHitTestVisible="False">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BackgroundImagePath}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImagePath}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageStretch}" Value="Fill">
                                        <Setter Property="Stretch" Value="Fill"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageStretch}" Value="Uniform">
                                        <Setter Property="Stretch" Value="Uniform"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageStretch}" Value="UniformToFill">
                                        <Setter Property="Stretch" Value="UniformToFill"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageStretch}" Value="None">
                                        <Setter Property="Stretch" Value="None"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="Top">
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="Bottom">
                                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="Left">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="Right">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="TopLeft">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="TopRight">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="BottomLeft">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BackgroundImageAlignment}" Value="BottomRight">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Border>
                <ScrollViewer x:Name="AccountScrollViewer" VerticalScrollBarVisibility="Auto" Padding="12,8" Background="Transparent"
                              PreviewMouseDown="AccountList_PreviewMouseDown"
                              PreviewMouseMove="AccountList_PreviewMouseMove"
                              PreviewMouseUp="AccountList_PreviewMouseUp">
                    <ScrollViewer.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Add Account" Command="{Binding AddAccountCommand}"/>
                            <MenuItem Header="Remove Account" Command="{Binding RemoveSelectedAccountsCommand}" IsEnabled="{Binding SelectedAccounts.Count, Converter={StaticResource IntToBoolConverter}}"/>
                            <Separator/>
                            <MenuItem Header="Copy">
                                <MenuItem Header="Copy Username" Command="{Binding CopyUsernameCommand}" CommandParameter="{Binding SelectedAccounts[0]}"/>
                                <MenuItem Header="Copy Password" Command="{Binding CopyPasswordCommand}" CommandParameter="{Binding SelectedAccounts[0]}"/>
                                <MenuItem Header="Copy User Pass Combo" Command="{Binding CopyComboCommand}" CommandParameter="{Binding SelectedAccounts[0]}"/>
                                <MenuItem Header="Copy Profile" Command="{Binding CopyProfileCommand}" CommandParameter="{Binding SelectedAccounts[0]}"/>
                                <MenuItem Header="Copy UserId" Command="{Binding CopyUserIdCommand}" CommandParameter="{Binding SelectedAccounts[0]}"/>
                            </MenuItem>
                            <MenuItem Header="Sort Alphabetically" Command="{Binding SortAlphabeticallyCommand}"/>
                            <MenuItem Header="Quick Log In" Command="{Binding QuickLogInAsyncCommand}" CommandParameter="{Binding SelectedAccounts[0]}"/>
                            <MenuItem Header="Groups">
                                <MenuItem Header="Create Group" Command="{Binding CreateGroupCommand}"/>
                                <MenuItem Header="Move Account To" ItemsSource="{Binding AvailableGroupsForMove}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding}"/>
                                            <Setter Property="Command" Value="{Binding DataContext.MoveAccountToGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Setter Property="CommandParameter">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ContextMenu}"/>
                                                        <Binding />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                            </MenuItem>
                            <MenuItem Header="Help" Command="{Binding HelpCommand}"/>
                        </ContextMenu>
                    </ScrollViewer.ContextMenu>
                        <ListBox x:Name="AccountList"
                                 SelectionMode="Extended"
                                 ItemsSource="{Binding DisplayItems}"
                                 SelectionChanged="AccountList_SelectionChanged"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Resources>
                                <!-- Account Group Template -->
                                <DataTemplate DataType="{x:Type Models:AccountGroup}">
                                    <Border Background="Transparent" Padding="0,4"
                                            PreviewMouseMove="ListBoxItem_PreviewMouseMove"
                                            Drop="ListBoxItem_Drop" AllowDrop="True">
                                        <Border Background="{StaticResource GlassBackgroundBrush}" Padding="12,8" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Arrow Toggle Button - Separate from group area -->
                                                <Button Grid.Column="0" 
                                                        Click="ArrowButton_Click"
                                                        Tag="{Binding}"
                                                        Background="Transparent" 
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        Margin="0,0,8,0"
                                                        Width="16" Height="16"
                                                        Cursor="Hand"
                                                        VerticalAlignment="Center">
                                                    <Path Data="M7,10L12,15L17,10" 
                                                          Stroke="{StaticResource PrimaryAccentBrush}" 
                                                          StrokeThickness="2" 
                                                          Fill="Transparent"
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center">
                                                        <Path.RenderTransform>
                                                            <RotateTransform CenterX="12" CenterY="12">
                                                                <RotateTransform.Angle>
                                                                    <Binding Path="IsExpanded" Converter="{StaticResource InverseBoolConverter}"/>
                                                                </RotateTransform.Angle>
                                                            </RotateTransform>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Button>
                                                
                                                <!-- Group Name and Count Area -->
                                                <Border Grid.Column="1" 
                                                        Background="Transparent"
                                                        MouseLeftButtonDown="GroupArea_MouseLeftButtonDown"
                                                        Tag="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource PrimaryAccentBrush}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="{Binding Accounts.Count, StringFormat=' ({0})', FallbackValue=''}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Context Menu for Groups -->
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit Name" Click="EditGroupNameMenuItem_Click" Tag="{Binding}"/>
                                                <MenuItem Header="Delete Group" Click="DeleteGroupMenuItem_Click" Tag="{Binding}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                    </Border>
                                </DataTemplate>

                                <!-- Account Template -->
                                <DataTemplate DataType="{x:Type Models:Account}">
                                    <Border x:Name="Row" Style="{StaticResource AcctRow}" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Add Account" Command="{Binding PlacementTarget.Tag.AddAccountCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Remove Account" Command="{Binding PlacementTarget.Tag.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Open in Browser" Command="{Binding PlacementTarget.Tag.OpenBrowserCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Copy">
                                                    <MenuItem Header="Copy Username" Command="{Binding PlacementTarget.Tag.CopyUsernameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Copy Password" Command="{Binding PlacementTarget.Tag.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Copy User Pass Combo" Command="{Binding PlacementTarget.Tag.CopyComboCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Copy Profile" Command="{Binding PlacementTarget.Tag.CopyProfileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Copy UserId" Command="{Binding PlacementTarget.Tag.CopyUserIdCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                </MenuItem>
                                                <MenuItem Header="Sort Alphabetically" Command="{Binding PlacementTarget.Tag.SortAlphabeticallyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Quick Log In" Command="{Binding PlacementTarget.Tag.QuickLogInAsyncCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="Edit Description" Command="{Binding PlacementTarget.Tag.EditDescriptionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="Groups">
                                                    <MenuItem Header="Create Group" Command="{Binding PlacementTarget.Tag.CreateGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="Move Account To" ItemsSource="{Binding PlacementTarget.Tag.AvailableGroupsForMove, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.ItemContainerStyle>
                                                            <Style TargetType="MenuItem">
                                                                <Setter Property="Header" Value="{Binding}"/>
                                                                <Setter Property="Command" Value="{Binding PlacementTarget.Tag.MoveAccountToGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                <Setter Property="CommandParameter">
                                                                    <Setter.Value>
                                                                        <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                                            <Binding Path="PlacementTarget.Tag" RelativeSource="{RelativeSource AncestorType=ContextMenu}"/>
                                                                            <Binding />
                                                                        </MultiBinding>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </MenuItem.ItemContainerStyle>
                                                    </MenuItem>
                                                </MenuItem>
                                                <MenuItem Header="Help" Command="{Binding PlacementTarget.Tag.HelpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar Image -->
                                            <Border Grid.Column="0" Width="32" Height="32" Margin="4,0,12,0" CornerRadius="16" Background="{StaticResource GlassBackgroundBrush}" VerticalAlignment="Center" ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding AvatarUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}" 
                                                           Stretch="UniformToFill" 
                                                           Width="32" Height="32"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           SnapsToDevicePixels="True">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <!-- Fallback icon when no avatar -->
                                                    <Path Data="M12,12C14.21,12 16,10.21 16,8C16,5.79 14.21,4 12,4C9.79,4 8,5.79 8,8C8,10.21 9.79,12 12,12M12,14C9.33,14 4,15.33 4,18V20H20V18C20,15.33 14.67,14 12,14Z" 
                                                          Fill="{StaticResource TextMutedBrush}" 
                                                          Width="16" Height="16" 
                                                          Stretch="Uniform" 
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </Grid>
                                            </Border>

                                            <!-- Status Indicator -->
                                            <Ellipse Grid.Column="1" Width="8" Height="8" Margin="0,0,12,0"
                                                     Fill="{Binding Status, Converter={StaticResource AccountStatusToColorConverter}}" VerticalAlignment="Center">
                                            </Ellipse>

                                            <!-- User Info -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Username}" Foreground="{StaticResource TextPrimaryBrush}" 
                                                            FontSize="14" FontWeight="SemiBold"/>
                                                <Border Background="{StaticResource GlassBackgroundBrush}" CornerRadius="4" Margin="10,0,0,0" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource PrimaryAccentBrush}" 
                                                               FontSize="11" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Description}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </StackPanel>

                                            <!-- Group Tag -->
                                            <Border Grid.Column="3" Background="{StaticResource GlassBackgroundBrush}" Padding="6,2" CornerRadius="4" VerticalAlignment="Center" Opacity="0.6">
                                                <TextBlock Text="{Binding Group}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.Resources>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="Padding" Value="0"/>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListBoxItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="PreviewMouseMove" Handler="ListBoxItem_PreviewMouseMove"/>
                                <EventSetter Event="Drop" Handler="ListBoxItem_Drop"/>
                                <Style.Triggers>
                                    <!-- Only apply selection styling to Account items, not AccountGroup items -->
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSelected}" Value="True"/>
                                            <Condition Binding="{Binding}" Value="{x:Type Models:Account}"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#1A6366F1"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                </ScrollViewer>

                <!-- Selection Rectangle Overlay -->
                <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False" Opacity="0.7">
                    <Rectangle x:Name="SelectionRectangle" 
                               Fill="#332196F3" 
                               Stroke="#FF2196F3" 
                               StrokeThickness="1" 
                               Visibility="Collapsed"/>
                </Canvas>
            </Grid>

                <!-- Status bar -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0"
                        Visibility="{Binding SettingsViewModel.DeveloperModeEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#99000000"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BackgroundImagePath}" Value="{x:Null}">
                                    <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding BackgroundImagePath}" Value="">
                                    <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SettingsViewModel.LowMemoryMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Ellipse Width="8" Height="8" Fill="#3B82F6" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                        
                         <TextBlock Grid.Column="2" Text="{Binding Accounts.Count, StringFormat='{}{0} TOTAL ACCOUNTS'}"
                                    Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold" 
                                    VerticalAlignment="Center"
                                    Visibility="{Binding SettingsViewModel.DeveloperModeEnabled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Settings View -->
            <views:SettingsView x:Name="SettingsView" DataContext="{Binding SettingsViewModel}" Panel.ZIndex="2">
                <views:SettingsView.Style>
                    <Style TargetType="views:SettingsView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsSettingsOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </views:SettingsView.Style>
            </views:SettingsView>
        </Grid>
    </Grid>
</Window>
