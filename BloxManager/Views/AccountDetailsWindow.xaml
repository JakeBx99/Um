<Window x:Class="BloxManager.Views.AccountDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Details" 
        Height="480" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundMainBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Arial">
    
    <Border Background="{StaticResource BackgroundMainBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Content -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <StackPanel>
                    <!-- Header Info -->
                    <ContentControl Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Profile Picture Placeholder -->
                            <Border Width="64" Height="64" CornerRadius="32" Margin="0,0,20,0"
                                    Background="{StaticResource GlassBackgroundBrush}" 
                                    BorderBrush="{StaticResource PrimaryAccentBrush}" BorderThickness="2">
                                <Path Data="M12,12C14.21,12 16,10.21 16,8C16,5.79 14.21,4 12,4C9.79,4 8,5.79 8,8C8,10.21 9.79,12 12,12M12,14C9.33,14 4,15.33 4,18V20H20V18C20,15.33 14.67,14 12,14Z" 
                                      Fill="{StaticResource PrimaryAccentBrush}" Width="24" Height="24" Stretch="Uniform"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Account.Username}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Account.Alias}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                                    <TextBlock Text=" • " Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding Account.UserId}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </ContentControl>

                    <!-- Account Info -->
                    <ContentControl Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Information" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Alias" VerticalAlignment="Center" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource Input}" Text="{Binding Account.Alias}" Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="1" Text="Group" VerticalAlignment="Center" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource Input}" Text="{Binding Account.Group}" Margin="0,0,0,12"/>

                                <TextBlock Grid.Row="2" Text="Status" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Fill="{Binding Account.IsValid, Converter={StaticResource BoolToColorConverter}}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Account.IsValid, Converter={StaticResource BoolToStatusConverter}}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ContentControl>

                    <!-- Description -->
                    <ContentControl Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Description" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBox Style="{StaticResource Input}" Text="{Binding Account.Description}" Height="80" 
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Tag="Add notes about this account..."/>
                        </StackPanel>
                    </ContentControl>

                    <!-- Actions -->
                    <ContentControl Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Launch Browser" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="Refresh" Style="{StaticResource SecondaryActionButton}"/>
                            </Grid>
                        </StackPanel>
                    </ContentControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="1" Background="{StaticResource BackgroundSecondaryBrush}" CornerRadius="0,0,16,16" Padding="24,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="CloseButton_Click" Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                    <Button Content="Save Changes" Style="{StaticResource PrimaryActionButton}" Width="140"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
