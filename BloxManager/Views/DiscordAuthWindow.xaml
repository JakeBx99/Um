<Window x:Class="BloxManager.Views.DiscordAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BloxManager - Discord Authentication" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundMainBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Arial">

    <Border Background="{StaticResource BackgroundMainBrush}" CornerRadius="8">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Discord Authentication Required" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryAccentBrush}"/>
                <TextBlock Text="BloxManager requires Discord authentication to verify you have the required role." 
                           FontSize="12" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Server Info -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource GlassBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="16" 
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="📋 Required Server &amp; Role" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Server ID: 1476897616049733692" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Required Role ID: 1476897643606184020" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Authentication Status -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource GlassBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="16" 
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Authentication Status" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="StatusTextBlock"
                                       Text="{Binding StatusMessage}"
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- User Info (shown when authenticated) -->
                    <Border x:Name="UserInfoPanel"
                            Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource GlassBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="16" 
                            Margin="0,0,0,16"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="User Information" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Username: " 
                                           FontWeight="Medium" 
                                           FontSize="12"/>
                                <TextBlock x:Name="UsernameTextBlock"
                                           Text="{Binding UserInfo.Username}"
                                           FontSize="12" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Discriminator: " 
                                           FontWeight="Medium" 
                                           FontSize="12"/>
                                <TextBlock x:Name="DiscriminatorTextBlock"
                                           Text="{Binding UserInfo.Discriminator}"
                                           FontSize="12" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Role Status: " 
                                           FontWeight="Medium" 
                                           FontSize="12"/>
                                <TextBlock x:Name="RoleStatusTextBlock"
                                           Text="{Binding RoleStatus}"
                                           FontSize="12" 
                                           Foreground="{Binding RoleStatusColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Instructions -->
                    <Border Background="{StaticResource SurfaceBrush}" 
                            BorderBrush="{StaticResource GlassBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="How to Authenticate" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="1. Click 'Authenticate with Discord' below" 
                                       FontSize="12" 
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="2. Authorize BloxManager to access your Discord account" 
                                       FontSize="12" 
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="3. We'll verify you have the required role" 
                                       FontSize="12" 
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="4. If successful, BloxManager will unlock" 
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Exit" 
                        Click="ExitButton_Click"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="{StaticResource GlassBorderBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Cursor="Hand"/>
                
                <Button Content="Authenticate with Discord" 
                        Command="{Binding AuthenticateCommand}"
                        IsEnabled="{Binding IsAuthenticating, Converter={StaticResource InverseBoolConverter}}"
                        Background="{StaticResource PrimaryAccentBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="16,8"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
