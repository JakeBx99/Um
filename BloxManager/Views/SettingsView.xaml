<UserControl x:Class="BloxManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BloxManager.Views"
             xmlns:imaging="clr-namespace:System.Windows.Media.Imaging;assembly=PresentationCore"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent"
             TextElement.Foreground="{StaticResource TextPrimaryBrush}"
             FontFamily="Segoe UI Variable, Segoe UI, Arial">
    
    <UserControl.Resources>
        <Geometry x:Key="IconSettings">M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41l-0.36,2.54c-0.59,0.24-1.13,0.57-1.62,0.94l-2.39-0.96c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.82,11.69,4.82,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.5c-1.93,0-3.5-1.57-3.5-3.5 s1.57-3.5,3.5-3.5s3.5,1.57,3.5,3.5S13.93,15.5,12,15.5z</Geometry>
        <Geometry x:Key="IconGames">M21,6H3C1.9,6,1,6.9,1,8v8c0,1.1,0.9,2,2,2h18c1.1,0,2-0.9,2-2V8C23,6.9,22.1,6,21,6z M11,15H9v-2h2V15z M11,11H9V9h2V11z M15,13h-4v-2h4V13z M19,15h-2v-2h2V15z M19,11h-2V9h2V11z</Geometry>
        <Geometry x:Key="IconPalette">M12,2C6.49,2 2,6.49 2,12C2,17.51 6.49,22 12,22C13.38,22 14.5,20.88 14.5,19.5C14.5,18.86 14.24,18.29 13.82,17.87C13.4,17.45 13.14,16.88 13.14,16.24C13.14,14.86 14.26,13.74 15.64,13.74H17.74C20.1,13.74 22,11.84 22,9.48C22,5.35 17.51,2 12,2M6.5,12C5.67,12 5,11.33 5,10.5C5,9.67 5.67,9 6.5,9C7.33,9 8,9.67 8,10.5C8,11.33 7.33,12 6.5,12M9.5,8C8.67,8 8,7.33 8,6.5C8,5.67 8.67,5 9.5,5C10.33,5 11,5.67 11,6.5C11,7.33 10.33,8 9.5,8M14.5,8C13.67,8 13,7.33 13,6.5C13,5.67 13.67,5 14.5,5C15.33,5 16,5.67 16,6.5C16,7.33 15.33,8 14.5,8M17.5,12C16.67,12 16,11.33 16,10.5C16,9.67 16.67,9 17.5,9C18.33,9 19,9.67 19,10.5C19,11.33 18.33,12 17.5,12Z</Geometry>
        <Geometry x:Key="IconClose">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</Geometry>
        <Geometry x:Key="IconReset">M12.5,8c-2.65,0-5.05,1-6.9,2.6L2,7v9h9l-3.62-3.62c1.39-1.16,3.16-1.88,5.12-1.88c3.54,0,6.55,2.31,7.6,5.5l2.37-0.78 C21.08,11.03,17.15,8,12.5,8z</Geometry>
        <Geometry x:Key="IconFolder">M20,6h-8l-2-2H4C2.9,4,2,4.9,2,6v12c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z</Geometry>

        <Style x:Key="CategoryButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="4,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource GlassBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryAccentGradient}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource GlassBackgroundBrush}" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource GlassBackgroundBrush}" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="20,24,20,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image x:Name="LogoImageSidebar" Grid.Column="0" Source="{x:Null}" Width="24" Height="24" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="Settings" FontSize="18" FontWeight="Bold"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="8,0">
                        <RadioButton Style="{StaticResource CategoryButton}" IsChecked="{Binding SelectedCategory, Converter={StaticResource EqualityConverter}, ConverterParameter='General'}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconSettings}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="General"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource CategoryButton}" IsChecked="{Binding SelectedCategory, Converter={StaticResource EqualityConverter}, ConverterParameter='Game'}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconGames}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Game"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource CategoryButton}" IsChecked="{Binding SelectedCategory, Converter={StaticResource EqualityConverter}, ConverterParameter='Customisation'}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPalette}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Customisation"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <Button Grid.Row="2" Style="{StaticResource SecondaryActionButton}" Margin="12,20" Command="{Binding OpenDataFolderCommand}">
                        <TextBlock Text="Open Data Folder" FontSize="11"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header & Close -->
                <Grid Margin="24,24,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="LogoImageHeader" Grid.Column="0" Source="{x:Null}" Width="24" Height="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedCategory}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Style="{StaticResource IconButton}"
                            Command="{Binding DataContext.OpenAccountsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Path Data="{StaticResource IconClose}" Fill="{StaticResource TextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Category Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
                    <ContentControl>
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <!-- General -->
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="General">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel>
                                                    <ContentControl Style="{StaticResource SettingsCard}">
                                                        <StackPanel>
                                                            <CheckBox Content="Enable Multi-Roblox" IsChecked="{Binding MultiRobloxEnabled}" Margin="0,0,0,16"/>
                                                            <CheckBox Content="Save Passwords" IsChecked="{Binding SavePasswordsEnabled}" Margin="0,0,0,16"/>
                                                            <CheckBox Content="Developer Mode" IsChecked="{Binding DeveloperModeEnabled}" Margin="0,0,0,16"/>
                                                            <CheckBox Content="Auto-refresh Cookies" IsChecked="{Binding AutoRefreshCookies}" Margin="0,0,0,16"/>
                                                            <CheckBox Content="Minimize to Tray" IsChecked="{Binding MinimizeToTray}" Margin="0,0,0,16"/>
                                                            <CheckBox Content="Auto Update" IsChecked="{Binding CheckForUpdates}" Margin="0,0,0,6"/>
                                                            <Button Style="{StaticResource PrimaryActionButton}" Command="{Binding OpenErrorLogsFileCommand}" Margin="0,8,0,0">
                                                                <TextBlock Text="View Error Logs" FontSize="11"/>
                                                            </Button>
                                                            <Button Style="{StaticResource SecondaryActionButton}" Command="{Binding ClearLogsCommand}" Margin="0,16,0,0" Visibility="{Binding DeveloperModeEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="Clear Logs" FontSize="11"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </ContentControl>
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <!-- Game -->
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="Game">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel>
                                                    <ContentControl Style="{StaticResource SettingsCard}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Text="Place ID" VerticalAlignment="Center" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                                                <TextBox Style="{StaticResource Input}" Text="{Binding PlaceId, UpdateSourceTrigger=PropertyChanged}" Tag="Place ID"/>
                                                                <TextBlock Text="{Binding GameName}" Margin="4,4,0,0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                                            </StackPanel>

                                                            <TextBlock Grid.Row="1" Text="Job ID" VerticalAlignment="Center" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource Input}" Text="{Binding JobId}" Margin="0,0,0,12" Tag="Job ID"/>

                                                            <TextBlock Grid.Row="2" Text="Launch Data" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource Input}" Text="{Binding LaunchData}" Tag="Launch Data"/>
                                                            
                                                            <TextBlock Grid.Row="3" Text="Join Interval (s)" VerticalAlignment="Center" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                                                                <TextBox Style="{StaticResource Input}" Width="120" Text="{Binding JoinDelaySeconds}" Tag="Join Delay"/>
                                                                <TextBlock Text=" Set delay between account launches (0 = instant)" Margin="8,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </ContentControl>
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>

                                    <!-- Customisation -->
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="Customisation">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel>
                                                    <!-- Background Image Section -->

                                                    <!-- Background Image Path -->
                                                    <ContentControl Style="{StaticResource SettingsCard}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Background image path" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                    <Button Style="{StaticResource IconButton}" Command="{Binding ClearBackgroundImageCommand}" Margin="8,-4,0,0" ToolTip="Reset">
                                                                        <Path Data="{StaticResource IconReset}" Fill="{StaticResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                                                    </Button>
                                                                </StackPanel>
                                                                <TextBlock Text="File location of the image used in the background of the window." FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                                                <TextBlock Text="{Binding BackgroundImagePath}" FontSize="10" Foreground="{StaticResource PrimaryAccentBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                                <TextBlock Text="720 × 324 px" 
                                                                           FontSize="11" Foreground="{StaticResource PrimaryAccentBrush}" Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Style="{StaticResource IconButton}" Command="{Binding SelectBackgroundImageCommand}" VerticalAlignment="Center" Margin="16,0,0,0">
                                                                <Path Data="{StaticResource IconFolder}" Fill="{StaticResource TextSecondaryBrush}" Width="18" Height="18" Stretch="Uniform"/>
                                                            </Button>
                                                        </Grid>
                                                    </ContentControl>

                                                    <!-- Image Controls -->
                                                    <ContentControl Style="{StaticResource SettingsCard}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="140"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>  <!-- Header -->
                                                                <RowDefinition Height="Auto"/>  <!-- Stretch label -->
                                                                <RowDefinition Height="Auto"/>  <!-- Alignment label -->
                                                                <RowDefinition Height="Auto"/>  <!-- Alignment caption -->
                                                                <RowDefinition Height="Auto"/>  <!-- Alignment grid -->
                                                                <RowDefinition Height="Auto"/>  <!-- Opacity -->
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Image settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>

                                                            <TextBlock Grid.Row="1" Text="Stretch" Style="{StaticResource SectionHeader}"/>
                                                            <ComboBox Grid.Row="1" Grid.Column="1" 
                                                                      ItemsSource="{Binding StretchModeOptions}" 
                                                                      DisplayMemberPath="Label" 
                                                                      SelectedValuePath="Key" 
                                                                      SelectedValue="{Binding BackgroundImageStretch}" Margin="0,0,0,16"
                                                                      Style="{StaticResource Combo}"/>

                                                            <TextBlock Grid.Row="2" Text="Alignment" Style="{StaticResource SectionHeader}"/>
                                                            <TextBlock Grid.Row="3" Text="Choose how the image aligns within the window." Style="{StaticResource Caption}"/>
                                                            
                                                            <!-- 3x3 Alignment Grid -->
                                                            <Border Grid.Row="4" Grid.Column="1" Background="{StaticResource GlassBackgroundBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,16">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <!-- Top Row -->
                                                                    <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="TopLeft" 
                                                                            ToolTip="Top Left">
                                                                        <Rectangle Width="20" Height="20" Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                    </Button>
                                                                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="Top" 
                                                                            ToolTip="Top">
                                                                        <Grid Width="24" Height="24">
                                                                            <Rectangle Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                            <Line X1="0" Y1="4" X2="24" Y2="4" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                        </Grid>
                                                                    </Button>
                                                                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="TopRight" 
                                                                            ToolTip="Top Right">
                                                                        <Rectangle Width="20" Height="20" Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                    </Button>
                                                                    
                                                                    <!-- Middle Row -->
                                                                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="Left" 
                                                                            ToolTip="Left">
                                                                        <Grid Width="24" Height="24">
                                                                            <Rectangle Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                            <Line X1="4" Y1="0" X2="4" Y2="24" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                        </Grid>
                                                                    </Button>
                                                                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="Center" 
                                                                            ToolTip="Center">
                                                                        <Grid Width="24" Height="24">
                                                                            <Rectangle Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                            <Line X1="0" Y1="12" X2="24" Y2="12" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                        </Grid>
                                                                    </Button>
                                                                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="Right" 
                                                                            ToolTip="Right">
                                                                        <Grid Width="24" Height="24">
                                                                            <Rectangle Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                            <Line X1="20" Y1="0" X2="20" Y2="24" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                        </Grid>
                                                                    </Button>
                                                                    
                                                                    <!-- Bottom Row -->
                                                                    <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="BottomLeft" 
                                                                            ToolTip="Bottom Left">
                                                                        <Rectangle Width="20" Height="20" Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                    </Button>
                                                                    <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="Bottom" 
                                                                            ToolTip="Bottom">
                                                                        <Grid Width="24" Height="24">
                                                                            <Rectangle Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                            <Line X1="0" Y1="20" X2="24" Y2="20" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                        </Grid>
                                                                    </Button>
                                                                    <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource AlignmentButton}" 
                                                                            Command="{Binding SetAlignmentCommand}" CommandParameter="BottomRight" 
                                                                            ToolTip="Bottom Right">
                                                                        <Rectangle Width="20" Height="20" Fill="Transparent" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="2"/>
                                                                    </Button>
                                                                </Grid>
                                                            </Border>

                                                            <Grid Grid.Row="5" Grid.ColumnSpan="2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="140"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="Opacity" Style="{StaticResource SectionHeader}" Margin="0"/>
                                                                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding BackgroundImageOpacity}" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding BackgroundImageOpacity, StringFormat={}{0:P0}}" 
                                                                           FontSize="11" Foreground="{StaticResource PrimaryAccentBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                            </Grid>
                                                        </Grid>
                                                    </ContentControl>
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{StaticResource BackgroundSecondaryBrush}" Padding="24,16" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset Defaults" Command="{Binding ResetSettingsCommand}" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                        <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryActionButton}" Width="120"/>
                    </StackPanel>
                </Border>

                <!-- Loading Overlay -->
                <Grid Grid.RowSpan="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Background="#A0000000"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="42" Height="42" Foreground="{StaticResource PrimaryAccentBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
