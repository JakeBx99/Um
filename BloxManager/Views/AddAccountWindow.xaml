<Window x:Class="BloxManager.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Account"        
        Height="360" Width="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Arial"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="{StaticResource BackgroundMainBrush}" 
            CornerRadius="16" 
            BorderBrush="{StaticResource GlassBorderBrush}" 
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Height="40" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" 
                              Fill="{StaticResource PrimaryAccentBrush}" 
                              Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Add Account" 
                                   FontSize="12" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="24,0,24,10">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Opening Roblox login..." 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    
                    <Border Background="{StaticResource GlassBackgroundBrush}" 
                            CornerRadius="12" 
                            Padding="16" 
                            BorderBrush="{StaticResource GlassBorderBrush}" 
                            BorderThickness="1"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="The Roblox login window will open automatically. After you sign in, the account will be added." 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       TextWrapping="Wrap" 
                                       FontSize="13" 
                                       LineHeight="18"/>
                            
                            <Grid Margin="0,20,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ProgressBar IsIndeterminate="True" 
                                             Height="8" 
                                             Foreground="{StaticResource PrimaryAccentGradient}" 
                                             Background="{StaticResource BackgroundSecondaryBrush}" 
                                             BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid x:Name="TemplateRoot">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="4" HorizontalAlignment="Left"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" 
                    Background="{StaticResource GlassBackgroundBrush}" 
                    CornerRadius="0,0,16,16" 
                    Padding="20,16"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                               VerticalAlignment="Center" 
                               Foreground="{StaticResource PrimaryAccentBrush}" 
                               FontSize="12" FontWeight="SemiBold"/>
                    
                    <Button Grid.Column="1" Content="Cancel" 
                            Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryActionButton}"
                            Width="80"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
